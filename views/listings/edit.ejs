<% layout("/layouts/boilerplate.ejs") %>
<div class="row mt-3">
  <div class="col-8 offset-2">
    <body>
      <h3>Edit details of your listing:</h3>
      <form action="/listings/<%=listing._id%>?_method=PUT" method="post" novalidate class="needs-validation">
        <div class="mb-3 mt-2">
          <label for="title" class="form-label">Title</label>
          <input
            name="listing[title]"
            type="text"
            value="<%= listing.title %>"
            class="form-control"
            required
          />
          <div class="invalid-feedback">Title should be valid</div>
        </div>
        <br />
    
        <div class="mb-3">
          <label for="description" class="form-label">Description</label>
          <textarea
            name="listing[description]"
            rows="5"
            cols="100"
            class="form-control"
            required><%= listing.description %>
          </textarea>
          <div class="invalid-feedback">valid description is not given</div>
        </div>
        <br />
    
        <div class="mb-3">
          <label for="image" class="form-label">Image</label>
          <input
            type="text"
            name="listing[image]"
            value="<%= listing.image %>"
            class="form-control"
            required
          />
          <div class="invalid-feedback">Valid image link is not given</div>
        </div>
        <br />

        <div class="row">
          <div class="mb-3 col-md-4">
            <label for="price" class="form-label">Price</label>
            <input
              name="listing[price]"
              type="number"
              value="<%= listing.price %>"
              class="form-control"
              required
            />
            <div class="invalid-feedback">Price should be valid</div>
          </div>

          <div class="mb-3 col-md-8">
          <label for="country" class="form-label">Country</label>
          <input
            type="text"
            name="listing[country]"
            value="<%= listing.country %>"
            class="form-control"
            required
          />
          <div class="invalid-feedback">valid country is not given</div>
          </div>
        </div>
        <br />
    
        <div  class="mb-3">
          <label for="location" class="form-label">Location</label>
          <input
            name="listing[location]"
            type="text"
            value="<%= listing.location %>"
            class="form-control"
            required
          />
          <div class="invalid-feedback">Location is not valid</div>
        </div>
    
        <br />
        <button class="add-btn btn btn-dark d-block mx-3 mb-3">Edit</button>
      </form>
    </body>
  </div>
</div>
