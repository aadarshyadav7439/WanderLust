<% layout("/layouts/boilerplate.ejs") %>
<div class="row">
    <div class="col-8 offset-2 mt-3">

        <h3 class="mb-1" id="title_show"><%=listing.title%></h3>
    </div>    
        <div class="card col-7 offset-2" >
                <img src="<%= listing.image %>" class="card-img-top show-img" alt="listing_img" style="height: 20rem;">
                <div class="card-body">
                    <p class="card-text" >
                        <%= listing.description %> <br>
                        ₹<%= listing.price.toLocaleString("en-IN") %> <br>
                        <%= listing.location %> <br>
                        <%= listing.country %>
                    </p>                
                </div>
        </div>

        <div class="btns">
            <a href="/listings/<%=listing.id%>/edit" class="btn btn-dark col-1 offset-2 add-btn">Edit</a>
            <br><br>
            <form action="/listings/<%=listing.id%>?_method=delete" method="post">
                <button class="btn btn-dark offset-4">Delete</button>
            </form>
        </div>
        <hr>
        <div class="col-8 offset-2">
            <h4  class="mb-3">Leave a review </h4>
            <form  class="mb-3" action="/listings/<%=listing.id%>/reviews" method="post">
                <div class="mb-3 mt-4">
                    <label for="rating" class="form-label">Rating</label>
                    <input type="range" min="1" max="5" class="form-range" id="rating" name="review[rating]">
                </div>
                <div class="mb-3">
                    <label for="comment" class="form-label">Comments </label>
                    <textarea name="review[comment]" id="comment"  class="form-control" rows="5"></textarea>
                </div>

                <button class="btn btn-outline-dark">Submit</button>
            </form>
        </div>
</div>

